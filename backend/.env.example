# Backend configuration
# All keys are optional — the defaults below work for local dev out of the box.

# Database (SQLite in backend/data/app.db by default)
# DB_URL=sqlite+aiosqlite:///./data/app.db

# CORS allowlist for the Next.js frontend
# CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Session manager
# MAX_SESSIONS=20
# SESSION_IDLE_TIMEOUT_SECONDS=1800
# SESSION_CLEANUP_INTERVAL_SECONDS=300

# Attachments
# MAX_ATTACHMENT_BYTES=10485760
# MAX_ATTACHMENTS_PER_MESSAGE=10

# GenericAgent language ("zh" or "en"). Passed through to GA as GA_LANG.
# GA_LANG=zh
